{
  "name": "symtorch-monorepo",
  "version": "0.27.0",
  "private": true,
  "type": "module",
  "description": "SymTorch: differentiable tensors and neuro-symbolic agents for TypeScript.",
  "dependencies": {
    "@symtorch/agent": "workspace:*",
    "@symtorch/core": "workspace:*",
    "@symtorch/logic": "workspace:*",
    "@symtorch/nn": "workspace:*",
    "@symtorch/webgpu": "workspace:*"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false",
    "demo:gradients": "tsx scripts/demo-gradient-checks.ts",
    "demo:rule": "tsx scripts/demo-rule-training.ts",
    "demo:ledger": "tsx scripts/demo-agent-ledger.ts",
    "demo:memory": "pnpm build && tsx scripts/demo-holographic-memory.ts",
    "demo:policy": "pnpm build && tsx scripts/demo-policy-bundle.ts",
    "demo:golden-policy": "pnpm build && tsx scripts/demo-golden-policy.ts",
    "demo:policy-fixtures": "pnpm build && tsx scripts/demo-policy-fixtures.ts",
    "demo:all": "pnpm demo:gradients && pnpm demo:rule && pnpm demo:ledger && pnpm demo:memory && pnpm demo:policy && pnpm demo:golden-policy && pnpm demo:policy-fixtures",
    "ledger:replay": "tsx scripts/replay-ledger.ts",
    "playground:test": "vitest run tests/browser-playground.test.ts",
    "playground:browser": "vite --config examples/browser-playground/vite.config.ts",
    "playground:build": "vite build --config examples/browser-playground/vite.config.ts",
    "playground:smoke": "pnpm playground:build && tsx scripts/smoke-browser-playground.ts",
    "playground:e2e": "playwright test --config tests/playground/playwright.config.ts",
    "example:linear": "tsx examples/linear-regression/src/index.ts",
    "example:routing": "tsx examples/neuro-symbolic-routing/src/index.ts",
    "example:trainable-routing": "tsx examples/trainable-routing/src/index.ts",
    "example:batch-routing": "tsx examples/batch-routing/src/index.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.0",
    "@webgpu/types": "^0.1.60",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.2.1",
    "tsx": "^4.20.3"
  }
}
